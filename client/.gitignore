# ============================================================
# CleverBooks Settlement Engine — .gitignore
# ============================================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js

# ---- Build outputs ----
dist/
build/
.next/
out/

# ---- Environment files  (NEVER commit secrets) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ---- Runtime / OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---- Editor ----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Testing ----
coverage/
.nyc_output/
junit.xml

# ---- Docker ----
# Keep docker-compose.yml committed; ignore local overrides
docker-compose.override.yml

# ---- Misc ----
*.pid
*.seed
*.pid.lock
.cache/
.parcel-cache/
.vite/